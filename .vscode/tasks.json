{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Jupyter Lab",
			"type": "shell",
			"command": "poetry run jupyter lab",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Jupyter.*",
					"endsPattern": ".*http://.*token=.*"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"showReuseMessage": false
			}
		}
	]
}
